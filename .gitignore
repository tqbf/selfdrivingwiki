# Generated codegen outputs — derived artifacts, NEVER committed.
# Regenerated at build time by `make version` (git state → GeneratedVersion.swift)
# and `make prompts` (prompts/*.md → GeneratedPrompts.swift); both are
# prerequisites of build/check/test/release. Bare `swift build` on a fresh
# clone won't find these — run `make version prompts` first, or use
# `make check`/`make build`/`make test`. See tools/versiongen + tools/promptgen.
Sources/WikiFSCore/GeneratedVersion.swift
Sources/WikiFSCore/GeneratedPrompts.swift

# swift-mutation-testing (schematized mutation testing — `make mutate`).
# Result cache + JSON/HTML/Sonar reports; all derived, never committed.
.swift-mutation-testing-cache/
mutation-report.json
mutation-report.html
sonar-mutation-report.json
