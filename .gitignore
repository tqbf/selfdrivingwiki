tmp/
:memory:*

# Generated codegen output — derived artifact, NEVER committed.
# Regenerated at build time by `make version` (git state → GeneratedVersion.swift);
# a prerequisite of build/check/test/release. Bare `swift build` on a fresh
# clone won't find it — run `make version` first, or use
# `make check`/`make build`/`make test`. See tools/versiongen.
# Note: prompts are no longer code-generated — they are bundled as .md
# resources in Sources/WikiFSCore/Resources/Prompts/ (loaded via Bundle.module).
Sources/WikiFSCore/GeneratedVersion.swift
# Shared keychain access group, baked from signing/local.config (TEAM_ID +
# APP_GROUP) so the app + wikid daemon agree. Same codegen/build-time contract
# as GeneratedVersion.swift above — run `make keychain` on a fresh clone.
Sources/WikiFSCore/GeneratedKeychain.swift

# swift-mutation-testing (schematized mutation testing — `make mutate`).
# Result cache + JSON/HTML/Sonar reports; all derived, never committed.
.swift-mutation-testing-cache/
mutation-report.json
mutation-report.html
sonar-mutation-report.json
